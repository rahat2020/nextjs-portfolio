# Base URL of the backend REST API (no trailing slash).
# Falls back to the production API if unset.
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# Public site URL used for canonical links, Open Graph tags, and the sitemap.
NEXT_PUBLIC_SITE_URL=https://kazirahat.com

# Web3Forms access key (get one free at https://web3forms.com) — powers the Contact form.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
